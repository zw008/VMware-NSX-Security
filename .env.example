# VMware NSX Security — Credential Template
# Copy to ~/.vmware-nsx-security/.env and fill in real passwords.
#
# Easiest path: run `vmware-nsx-security init` — it writes config.yaml + .env
# for you, stores the password grep-safe (b64:), and chmod 600s the file.
#
# Manual path:
#   cp .env.example ~/.vmware-nsx-security/.env
#   chmod 600 ~/.vmware-nsx-security/.env
#
# Naming convention: VMWARE_NSX_SECURITY_{TARGET_NAME_UPPER}_PASSWORD
#   - Replace hyphens with underscores
#   - Convert to UPPERCASE
#   - Example: target "nsx-prod" -> VMWARE_NSX_SECURITY_NSX_PROD_PASSWORD

# Passwords for targets defined in config.yaml
VMWARE_NSX_SECURITY_NSX_PROD_PASSWORD=
VMWARE_NSX_SECURITY_NSX_LAB_PASSWORD=

# Add more as needed — one per target in config.yaml
# VMWARE_NSX_SECURITY_NSX_DEV_PASSWORD=
